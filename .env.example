# Vacío a propósito: usamos el proxy de Vite (ver vite.config.js) para
# que /auth, /products, etc. sean same-origin y no haya CORS.
VITE_API_BASE_URL=

# Toda la app va contra el backend real (wh-backend en :8080) vía proxy de Vite.
# Poner en true para volver a datos mockeados (sin backend).

VITE_USE_MOCK=false

# Login también va contra el backend real.
VITE_USE_MOCK_AUTH=false
